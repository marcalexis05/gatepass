# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=gatepass_db

# Serveo Static Tunnel Configuration
# (This name will be your permanent, static public URL)
SERVEO_SUBDOMAIN=digital-gatepass

# Tunnel Run Mode (set to true to run silently in the background, false to show CMD window)
TUNNEL_SILENT=true