# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=gatepass_db

# Cloudflare Tunnel Configuration
# (Leave empty to use free random links without warning pages)
CLOUDFLARE_TUNNEL_TOKEN=
SYSTEM_URL=

# Tunnel Run Mode (set to true to run silently in the background, false to show CMD window)
TUNNEL_SILENT=true

shell:startup